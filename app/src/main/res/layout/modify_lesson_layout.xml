<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".AddCourseActivity"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/modify_lesson_text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0B1220"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E6E6E6"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilLessonName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:hintTextColor="#1D4ED8"
                    app:boxStrokeColor="#1D4ED8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:hint="@string/CourseTitle_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLessonNameModify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0B1220"
                        android:textColorHint="#9CA3AF"
                        android:inputType="textCapSentences"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDescription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="#1D4ED8"
                    app:hintTextColor="#1D4ED8"
                    app:layout_constraintTop_toBottomOf="@id/tilLessonName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:hint="@string/Description_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescriptionModify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0B1220"
                        android:textColorHint="#9CA3AF"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:maxLines="6"
                        android:gravity="top|start" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCredits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="#1D4ED8"
                    app:hintTextColor="#1D4ED8"
                    android:hint="@string/Credits_hint"
                    app:layout_constraintTop_toBottomOf="@id/tilDescription"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tilVideoId"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    android:layout_marginEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCreditsModify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0B1220"
                        android:textColorHint="#9CA3AF"
                        android:inputType="number"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilVideoId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxStrokeColor="#1D4ED8"
                    app:hintTextColor="#1D4ED8"
                    android:hint="@string/youtube_video_id"
                    app:endIconMode="custom"
                    app:endIconDrawable="@android:drawable/ic_menu_info_details"
                    app:layout_constraintTop_toBottomOf="@id/tilDescription"
                    app:layout_constraintStart_toEndOf="@id/tilCredits"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginStart="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVideoIdModify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#0B1220"
                        android:textColorHint="#9CA3AF"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilLessonGrade"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:hintTextColor="#1D4ED8"
                    app:boxStrokeColor="#1D4ED8"
                    app:layout_constraintBottom_toTopOf="@id/btnModifyLesson"
                    app:layout_constraintTop_toBottomOf="@+id/tilCredits"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:hint="@string/lessonGrade">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerLessonGradeModify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="#0B1220"
                        android:textColorHint="#9CA3AF"
                        tools:ignore="SpeakableTextPresentCheck" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModifyLesson"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/modify_lesson"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    app:backgroundTint="#1D4ED8"
                    app:cornerRadius="16dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tilLessonGrade" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/video_id_v"
            android:textColor="#6B7280"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/cardForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>