<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:padding="16dp">

        <TextView
            android:id="@+id/studentNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/chip4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="@string/student_name" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6200EA"
            android:textSize="12sp"
            app:chipBackgroundColor="#F3E8FF"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="32dp"
            app:layout_constraintBottom_toTopOf="@+id/buttonBlockStudent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/studentNameText"
            app:layout_constraintVertical_bias="0.0"
            android:text="@string/not_blocked" />

        <TextView
            android:id="@+id/studentAccountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#64748B"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/studentNameText"
            tools:text="ahmed@gmail.com" />

        <TextView
            android:id="@+id/creditsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_badge_light_purple"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#6200EA"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/studentAccountText"
            tools:text="Credits : 10" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#F1F5F9"
            app:layout_constraintTop_toBottomOf="@id/creditsText" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBlockStudent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/block_student"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_block"
            app:iconSize="16dp"
            app:iconTint="#EF4444"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:strokeColor="#FCA5A5"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRecoverStudent"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/unblock_student"
            android:textColor="#10B981"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_uses_time"
            app:iconSize="16dp"
            app:iconTint="#10B981"
            app:layout_constraintBottom_toBottomOf="@+id/buttonBlockStudent"
            app:layout_constraintEnd_toStartOf="@id/buttonBlockStudent"
            app:layout_constraintTop_toTopOf="@+id/buttonBlockStudent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>